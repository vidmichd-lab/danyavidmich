---
interface Props {
  id: string;
  class?: string;
}

const { id, class: className = "" } = Astro.props;

const filters = [
  ["all", "All"],
  ["branding", "Branding"],
  ["visual", "Visual Communications"],
  ["product", "Product Design"],
  ["web", "Web"],
  ["typography", "Typography"],
  ["merch", "Merch"],
  ["concept", "Concept"],
  ["posters", "Posters"]
] as const;
---

<div class:list={["portfolio-filters", className]} id={id}>
  {
    filters.map(([filter, label], index) => (
      <button
        aria-label={filter === "all" ? "Show all projects" : `Filter by ${label}`}
        class:list={["filter-button", index === 0 && "filter-button--active"]}
        data-filter={filter}
      >
        {label}
      </button>
    ))
  }
</div>
