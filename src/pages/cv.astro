  <script is:inline>
    function updateSaintPetersburgTime() {
      var target = document.getElementById("saint-petersburg-time");
      if (!target) return;
      target.textContent = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Europe/Moscow",
        hour: "2-digit",
        minute: "2-digit",
        timeZoneName: "short"
      }).format(new Date());
    }

    updateSaintPetersburgTime();
    window.setInterval(updateSaintPetersburgTime, 60000);
  </script>
