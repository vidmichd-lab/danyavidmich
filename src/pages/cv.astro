  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
      		<div class="about">

      		    <div>
      			<p>Lead Brand & Product Designer for tech companies</p>

      				<div class="mentioned">
              <p id="media">Multidisciplinary Design Lead with 8+ years of experience driving brand and product communication for large-scale tech platforms (Yandex, Badoo). Specialize in building scalable design systems, leading cross-functional teams, and integrating AI into creative production to increase speed, reduce costs, and improve campaign performance</p>
      			  </div>

              <div class="recruiter-summary">
