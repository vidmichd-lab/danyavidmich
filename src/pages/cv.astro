---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";

const subtitle = "Work Experience";
const tertiary = "";
const ogMeta = await getOGMeta("cv");
