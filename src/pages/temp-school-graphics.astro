---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";

const ogMeta = await getOGMeta("temp-school-graphics", `Danya Vidmich — Temp School Identity`);
const subtitle = "Temp School Identity";
const tertiary = "";
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
      		<div class="about">
      		    <div>

      			    </div>  
          </div>

          <div class="aboutzero"></div>

      		<div class="graphic project-content">

      			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/temp-school-graphics/1.webp")} loading="lazy" decoding="async" />
      			</div>


            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/temp-school-graphics/2.webp")} loading="lazy" decoding="async" />
            </div>

            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/temp-school-graphics/3.webp")} loading="lazy" decoding="async" />
            </div>

                      <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/temp-school-graphics/4.webp")} loading="lazy" decoding="async" />
            </div>

                      <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/temp-school-graphics/5.webp")} loading="lazy" decoding="async" />
            </div>

      		</div>
      	</div>
</BaseLayout>
