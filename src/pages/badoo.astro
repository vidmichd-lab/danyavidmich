---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";

const subtitle = "Badoo OOH \"Be Yourself With Me\"";
const tertiary = "";
const ogMeta = await getOGMeta("badoo");
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
          <div id="pageabout" class="about">
      		<div class="about9">
      		    <div>
<p>Developed the visual concept for Badoo’s first nationwide out-of-home campaign in Russia, “Be Yourself With Me,” adapting the global brand positioning into a locally relevant visual language. Defined the art direction and key visual system for large-scale placements, ensuring clarity and consistency across formats, and collaborated with the UK-based communications team on messaging and rollout. The campaign was approved and deployed across multiple cities, marking Badoo’s first large-scale offline presence in the Russian market.
</p>
      			    </div>  
          </div>
              			    </div>  

          <div class="aboutzero"></div>

      		<div class="graphic project-content">



              <div class="bigcard project-card">
                <img src={getOptimizedImagePath("/img/gr/badoo/1.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="bigcard project-card">
                <img src={getOptimizedImagePath("/img/gr/badoo/2.webp")} loading="lazy" decoding="async" />
              </div>

              <div  class="cards project-card">

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/badoo/3.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/badoo/4.webp")} loading="lazy" decoding="async" />
              </div>

    </div>
                      <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/badoo/5.webp")} loading="lazy" decoding="async" />
            </div>
                      <div  class="cards project-card">

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/badoo/6.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/badoo/7.webp")} loading="lazy" decoding="async" />
              </div>

      		</div>
      	</div>
      	    			    </div>
</BaseLayout>
