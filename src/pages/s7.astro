---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";

const ogMeta = await getOGMeta("s7", `Danya Vidmich — S7 Logistics Identity`);
const subtitle = "S7 Logistics Identity";
const tertiary = "";
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
      		<div class="about9">

      		    <div>

      		        <p>
      		                Developed a sub-brand for S7’s B2B logistics service, communicating 24-hour package delivery by air through a flexible cloud-based visual metaphor and a recognizable extension of the airline brand system.</p>
  <div class="button">
      			        <span class=".solar--play-circle-bold"></span><a href="https://logistics.s7.ru/">Open S7 Logistics</a>
      			    </div>
      			    </div>  
          </div>

          <div class="aboutzero"></div>

      		<div class="graphic project-content">

      			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/s7/1.webp")} loading="lazy" decoding="async" />
      			</div>


            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/s7/2.webp")} loading="lazy" decoding="async" />
            </div>

            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/gr/s7/3.webp")} loading="lazy" decoding="async" />
            </div>

      		</div>
      	</div>
</BaseLayout>
