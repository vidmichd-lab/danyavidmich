---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";
import { getProjectAIContent } from "@utils/aiContentStore";
import { getCases } from "@utils/casesStore";

const cases = await getCases();
const project = cases.find(c => c.slug === "apt-product");
const aiContent = project ? getProjectAIContent(project.id) : null;
const subtitle = aiContent?.subtitle || "Apt Product";
const tertiary = "";
const ogMeta = await getOGMeta("apt-product");
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
      		<div class="about9">
      		    <div>
      		             {aiContent?.longDescription ? (
      		               <p>{aiContent.longDescription}</p>
      		             ) : (
      		               <p>Co-founded and art-directed Apt, a dating app for meeting through city events. I shaped the product vision, designed the MVP, built the brand and launch communications, led a cross-functional team and helped grow the app to 6K+ MAU in the first six months.</p>
      		             )} 
      		                 		                <div class="button">
      			        <span class=".solar--play-circle-bold"></span><a href="https://vimeo.com/714390233">Watch showreel</a>
      			    </div>   
      			    </div>  
          </div>

          <div class="aboutzero"></div>

      		<div class="graphic project-content">

      			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/pr/apt/1.webp")} loading="lazy" decoding="async" />
      			</div>


            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/pr/apt/2.webp")} loading="lazy" decoding="async" />
            </div>

            <div class="bigcard project-card">
              <img src={getOptimizedImagePath("/img/pr/apt/3.webp")} loading="lazy" decoding="async" />
            </div>


      		</div>
      	</div>
      
</BaseLayout>
