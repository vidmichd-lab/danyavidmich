---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";

const ogMeta = await getOGMeta("bandlink", `Danya Vidmich — Bandlink Identity`);
const subtitle = "Bandlink Idenity";
const tertiary = "";
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
      		<div class="about">
      		    <div>
      		         <p>Relaunched the Bandlink analytics service identity and communication system for artists, covering visual language, SMM, CRM, events and product-adjacent touchpoints inside the Yandex Music ecosystem.</p>
      			    </div>  
          </div>

          <div class="aboutzero"></div>

      		<div class="graphic project-content">


            <div  class="cards project-card">

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/1.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/2.webp")} loading="lazy" decoding="async" />
              </div>
                    </div>

                              <div  class="cards project-card">

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/5.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/6.webp")} loading="lazy" decoding="async" />
              </div>
                    </div>


                        <div  class="cards project-card">

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/3.webp")} loading="lazy" decoding="async" />
              </div>

              <div class="card">
                <img src={getOptimizedImagePath("/img/gr/bandlink/4.webp")} loading="lazy" decoding="async" />
              </div>
              </div>
          </div>

    </div>
</BaseLayout>
