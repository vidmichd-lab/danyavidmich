---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import { getOGMeta } from "@utils/ogMeta";
import { getOptimizedImagePath } from "@utils/imageUtils";

const subtitle = "Branding Yandex Practicum PRO";
const tertiary = "";
const ogMeta = await getOGMeta("yandex-practicum-pro", "Danya Vidmich — Branding Yandex Practicum PRO");
---

<BaseLayout
  title={ogMeta.title}
  description={ogMeta.description}
  ogTitle={ogMeta.ogTitle}
  ogDescription={ogMeta.ogDescription}
  ogUrl={ogMeta.ogUrl}
  ogImage={ogMeta.ogImage}
>
  <Header subtitle={subtitle} tertiary={tertiary} />


        <div class="main">
              		<div class="about9">
      		    <div>
      		         <p>Led the Yandex Practicum Pro brand launch across identity, visual system, brandbook and AI-assisted production. The campaign delivered 154.2% of planned reach, 206.4% of planned traffic and a +652% search lift for the brand. I also built AI-assisted asset workflows that saved ~1.4M RUB in Q4 2025.</p>
      			    <div class="button">
      			        <a href="https://practicum.yandex.ru/pro/">Visit Practicum Pro</a>
      			    </div>   
      			    </div>  
          </div>

          <div class="aboutzero"></div>

      		<div class="graphic project-content">

      			    			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/yandex-practicum-pro/5.webp")} loading="lazy" decoding="async" />
      			</div>

      			    			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/yandex-practicum-pro/2.webp")} loading="lazy" decoding="async" />
      			</div>

      			    			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/yandex-practicum-pro/3.webp")} loading="lazy" decoding="async" />
      			</div>

      			    			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/yandex-practicum-pro/4.webp")} loading="lazy" decoding="async" />
      			</div>

      			    			<div class="bigcard project-card">
      				<img src={getOptimizedImagePath("/img/gr/yandex-practicum-pro/1.webp")} loading="lazy" decoding="async" />
      			</div>



      		</div>
      	</div>
</BaseLayout>
